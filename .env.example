# Copy to .env and restart Metro (npm start)
# Must match ONINS/.env GOOGLE_CLIENT_ID for Google Sign-In

# Full API base (optional — auto-detected from Metro on Expo Go)
# EXPO_PUBLIC_API_URL=http://192.168.1.10:8000/api

# Railway production backend (webdev + MySQL on Railway)
# EXPO_PUBLIC_API_URL=https://webdev-production-c694.up.railway.app/api
# EXPO_PUBLIC_API_WEB_URL=https://webdev-production-c694.up.railway.app

# Web origin for OAuth (optional)
# EXPO_PUBLIC_API_WEB_URL=http://192.168.1.10:8000

# Optional legacy reference (mobile Google sign-in uses ONINS /connect/google?platform=mobile)
# EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# Mercure hub for in-app realtime (default: same host as API on port 3000)
# EXPO_PUBLIC_MERCURE_URL=http://192.168.1.10:3000/.well-known/mercure

# Android FCM: copy google-services.json.example instructions — place google-services.json
# in project root AND android/app/ (same file), then rebuild the native app (npm run start:android).
